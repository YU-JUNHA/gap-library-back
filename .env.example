# Environment

APP_NAME="GAP Library API"
DEBUG=true
API_PREFIX="/api/v1"
FILE_STORAGE_ROOT="storage/uploads"
FILE_PUBLIC_PREFIX="/uploads"
DOCUMENT_STORAGE_ROOT="storage/documents"

# Database
DATABASE_URL="postgresql+psycopg://postgres:postgres@localhost:5432/gap_library"

# Security
JWT_SECRET_KEY="replace-this-with-a-secure-random-key"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# CORS (comma separated)
CORS_ORIGINS='["http://localhost:5173"]'
